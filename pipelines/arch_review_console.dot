// Architecture Review Pipeline -- Console Strategy
//
// 4 sequential domain specialists + Solutions Architect Lead.
// Lightest pipeline -- for CLI tools, scripts, and local-machine apps.
// No cloud or infrastructure stages. Focused on code quality,
// security, integration patterns, and performance.
//
// Agents: factory/agents/sa-{code-quality,security-console,
//         integration-console,performance-console}.md, sa-lead-console.md
//
// Called by: Dark Forge (dark_forge.dot) when DEPLOY_STRATEGY=console

digraph arch_review_console {
    graph [
        goal="Review a GitHub issue across 4 software quality domains and produce an Engineering Brief"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Approved Issue"]

    // --- Stage 1: Code Quality (patterns, maintainability, SOLID) ---
    sa_code_quality [
        shape=box,
        prompt="You are:\n$sa_code_quality_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: You are reviewing the PROPOSED FEATURE described in the issue, NOT auditing the entire existing codebase. Explore $workspace only to understand existing patterns that the feature should follow. Do NOT flag pre-existing code issues — only evaluate risks introduced by implementing this feature.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 2: Security (input validation, secrets, OWASP) ---
    // CRITICAL: Reviews ALL prior recommendations
    sa_security_console [
        shape=box,
        prompt="You are:\n$sa_security_console_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: You are reviewing the PROPOSED FEATURE described in the issue, NOT auditing the entire existing codebase. Only flag security risks INTRODUCED by this feature. Do NOT flag pre-existing security issues — those are tracked separately.\n\nReview prior stage recommendations for security implications.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 3: Integration (CLI UX, piping, exit codes, config) ---
    sa_integration_console [
        shape=box,
        prompt="You are:\n$sa_integration_console_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: You are reviewing the PROPOSED FEATURE described in the issue, NOT auditing the entire existing codebase. Explore $workspace only to understand existing integration patterns.\n\nEvaluate the proposed feature for:\n- How new CLI commands/options integrate with existing patterns\n- stdin/stdout/stderr usage in new functionality\n- Exit codes and error reporting for new operations\n- Compatibility with existing piping and config conventions\n- New environment variable requirements\n\nDo NOT flag pre-existing integration issues. Only evaluate what the feature introduces.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 4: Performance (runtime, memory, startup time) ---
    sa_performance_console [
        shape=box,
        prompt="You are:\n$sa_performance_console_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: You are reviewing the PROPOSED FEATURE described in the issue, NOT auditing the entire existing codebase. Explore $workspace only to understand existing performance patterns.\n\nEvaluate the proposed feature for:\n- Performance impact of new functionality\n- Memory usage of new operations\n- Impact on startup time\n- Async I/O considerations for new code paths\n- Algorithmic complexity of new operations\n\nDo NOT flag pre-existing performance issues. Only evaluate what the feature introduces.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Solutions Architect Lead (final synthesis) ---
    sa_lead_console [
        shape=box,
        prompt="You are:\n$sa_lead_console_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nYou have output from 4 specialist stages. Read their findings from the pipeline context.\n\nIMPORTANT: All specialist reviews are scoped to the PROPOSED FEATURE, not the existing codebase. Pre-existing issues should not factor into your verdict.\n\nSynthesize all reviews into an Engineering Brief:\n- Approved architectural approach for implementing the feature\n- Key constraints and risks the feature introduces\n- Implementation guidance per domain\n- Verdict: APPROVED | NEEDS_CHANGES | NEEDS_HUMAN\n\nOnly use NEEDS_HUMAN if the feature itself introduces high/critical risks that require human judgement. Do NOT escalate for pre-existing codebase issues.\n\nWrite the Engineering Brief to: $workspace/.dark-factory/specs/$issue_number/engineering-brief.md\n\nOutput your verdict as the final line: APPROVED, NEEDS_CHANGES, or NEEDS_HUMAN"
    ]

    // --- Verdict ---
    verdict [shape=diamond, label="SA Verdict?"]
    approved [shape=Msquare, label="Engineering Brief\n(APPROVED)"]
    needs_human [shape=house, label="Human Review Required"]

    // --- Flow: Sequential ---
    start -> sa_code_quality -> sa_security_console -> sa_integration_console -> sa_performance_console
    sa_performance_console -> sa_lead_console -> verdict

    verdict -> approved [label="APPROVED"]
    verdict -> sa_code_quality [label="NEEDS_CHANGES"]
    verdict -> needs_human [label="NEEDS_HUMAN"]
}
