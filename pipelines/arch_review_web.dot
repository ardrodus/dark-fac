// Architecture Review Pipeline -- Web Strategy
//
// 6 sequential domain specialists + Solutions Architect Lead.
// For web applications -- frontend, backend, database, security,
// performance, and integration concerns.
//
// Agents: factory/agents/sa-{frontend,backend,database-web,
//         security-web,performance-web,integration-web}.md, sa-lead-web.md
//
// Called by: Dark Forge (dark_forge.dot) when DEPLOY_STRATEGY=web

digraph arch_review_web {
    graph [
        goal="Review a GitHub issue across 6 web application domains and produce an Engineering Brief"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Approved Issue"]

    // --- Stage 1: Frontend (UI, UX, accessibility, responsive design) ---
    sa_frontend [
        shape=box,
        prompt="You are:\n$sa_frontend_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: Review the PROPOSED FEATURE described in the issue, NOT the entire existing codebase. Explore $workspace only to understand existing patterns the feature should follow. Do NOT flag pre-existing issues.\n\nEvaluate the proposed feature for:\n- UI component architecture for new components\n- State management approach for new functionality\n- Accessibility (WCAG compliance) in new UI\n- Responsive design for new views\n- Impact on bundle size\n- Consistency with existing design system\n\nIf the proposed feature does not involve your domain at all, you are free to respond with NO_OPINION_NEEDED. Do not force findings when the feature is outside your expertise. Output: {\"findings\": [\"NO_OPINION_NEEDED - feature does not involve frontend changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 2: Backend (API design, server architecture, business logic) ---
    sa_backend [
        shape=box,
        prompt="You are:\n$sa_backend_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: Review the PROPOSED FEATURE described in the issue, NOT the entire existing codebase. Explore $workspace only to understand existing patterns. Do NOT flag pre-existing issues.\n\nEvaluate the proposed feature for:\n- API design for new endpoints\n- Server architecture for new functionality\n- Business logic organization in new code\n- Error handling for new operations\n- Impact on session management or auth flow\n\nIf the proposed feature does not involve your domain at all, you are free to respond with NO_OPINION_NEEDED. Do not force findings when the feature is outside your expertise. Output: {\"findings\": [\"NO_OPINION_NEEDED - feature does not involve backend changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 3: Database (data modeling, queries, migrations) ---
    sa_database_web [
        shape=box,
        prompt="You are:\n$sa_database_web_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: Review the PROPOSED FEATURE described in the issue, NOT the entire existing codebase. Explore $workspace only to understand existing patterns. Do NOT flag pre-existing issues.\n\nEvaluate the proposed feature for:\n- New data models and schema changes\n- ORM usage in new code\n- Query performance of new operations\n- Migration needs for new tables/columns\n- Indexing for new queries\n\nIf the proposed feature does not involve your domain at all, you are free to respond with NO_OPINION_NEEDED. Do not force findings when the feature is outside your expertise. Output: {\"findings\": [\"NO_OPINION_NEEDED - feature does not involve database changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 4: Security (auth, OWASP, XSS, CSRF, secrets) ---
    // CRITICAL: Reviews ALL prior recommendations
    sa_security_web [
        shape=box,
        prompt="You are:\n$sa_security_web_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: Review the PROPOSED FEATURE described in the issue, NOT the entire existing codebase. Only flag security risks INTRODUCED by this feature. Do NOT flag pre-existing security issues.\n\nReview prior stage recommendations for security implications.\n\nEvaluate the proposed feature for:\n- Auth/authz requirements for new endpoints\n- OWASP top 10 risks in new code paths\n- XSS/CSRF risks in new UI or API surfaces\n- Secrets handling in new functionality\n- Input validation for new user inputs\n- Rate limiting needs for new endpoints\n\nIf the proposed feature does not introduce any security-relevant changes in your domain, you are free to respond with NO_OPINION_NEEDED. Do not force findings when the feature is outside your expertise. Output: {\"findings\": [\"NO_OPINION_NEEDED - feature does not introduce security-relevant changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 5: Performance (load time, caching, optimization) ---
    sa_performance_web [
        shape=box,
        prompt="You are:\n$sa_performance_web_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: Review the PROPOSED FEATURE described in the issue, NOT the entire existing codebase. Explore $workspace only to understand existing patterns. Do NOT flag pre-existing issues.\n\nEvaluate the proposed feature for:\n- Performance impact of new pages/components\n- Caching needs for new data\n- Lazy loading for new code paths\n- Database query performance for new operations\n- API response time for new endpoints\n- Bundle size impact\n\nIf the proposed feature does not involve your domain at all, you are free to respond with NO_OPINION_NEEDED. Do not force findings when the feature is outside your expertise. Output: {\"findings\": [\"NO_OPINION_NEEDED - feature does not have performance implications\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 6: Integration (APIs, third-party services, deployment) ---
    sa_integration_web [
        shape=box,
        prompt="You are:\n$sa_integration_web_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nIMPORTANT: Review the PROPOSED FEATURE described in the issue, NOT the entire existing codebase. Explore $workspace only to understand existing patterns. Do NOT flag pre-existing issues.\n\nEvaluate the proposed feature for:\n- New third-party API integrations needed\n- Webhook requirements for new functionality\n- New notification/email needs\n- Impact on CI/CD pipeline\n- New environment configuration requirements\n\nIf the proposed feature does not involve your domain at all, you are free to respond with NO_OPINION_NEEDED. Do not force findings when the feature is outside your expertise. Output: {\"findings\": [\"NO_OPINION_NEEDED - feature does not involve integration changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Solutions Architect Lead (final synthesis) ---
    sa_lead_web [
        shape=box,
        prompt="You are:\n$sa_lead_web_agent\n\nWorkspace: $workspace\nIssue: $issue\n\nYou have output from 6 specialist stages. Read their findings from the pipeline context.\n\nIMPORTANT: All specialist reviews are scoped to the PROPOSED FEATURE, not the existing codebase. Pre-existing issues should not factor into your verdict.\n\nSynthesize all reviews into an Engineering Brief:\n- Approved architectural approach for implementing the feature\n- Key constraints and risks the feature introduces\n- Implementation guidance per domain\n- Verdict: APPROVED | NEEDS_CHANGES | NEEDS_HUMAN\n\nIMPORTANT: Specialists may respond with NO_OPINION_NEEDED when the feature does not touch their domain. This is expected and valid -- respect it. Do NOT treat NO_OPINION_NEEDED as a gap or require every specialist to weigh in. Only synthesize findings from specialists who had substantive input.\n\nOnly use NEEDS_HUMAN if the feature itself introduces high/critical risks that require human judgement. Do NOT escalate for pre-existing codebase issues.\n\nWrite the Engineering Brief to: $workspace/.dark-factory/specs/$issue_number/engineering-brief.md\n\nOutput your verdict as the final line: APPROVED, NEEDS_CHANGES, or NEEDS_HUMAN"
    ]

    // --- Verdict ---
    verdict [shape=diamond, label="SA Verdict?"]
    approved [shape=Msquare, label="Engineering Brief\n(APPROVED)"]
    needs_human [shape=house, label="Human Review Required"]

    // --- Flow: Sequential ---
    start -> sa_frontend -> sa_backend -> sa_database_web
    sa_database_web -> sa_security_web -> sa_performance_web -> sa_integration_web
    sa_integration_web -> sa_lead_web -> verdict

    verdict -> approved [label="APPROVED"]
    verdict -> sa_frontend [label="NEEDS_CHANGES"]
    verdict -> needs_human [label="NEEDS_HUMAN"]
}
