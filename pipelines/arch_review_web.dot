// Architecture Review Pipeline -- Web Strategy
//
// 6 sequential domain specialists + Solutions Architect Lead.
// For web applications -- frontend, backend, database, security,
// performance, and integration concerns.
//
// Agents: factory/agents/sa-{frontend,backend,database-web,
//         security-web,performance-web,integration-web}.md, sa-lead-web.md
//
// Called by: Dark Forge (dark_forge.dot) when DEPLOY_STRATEGY=web

digraph arch_review_web {
    graph [
        goal="Review a GitHub issue across 6 web application domains and produce an Engineering Brief"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Approved Issue"]

    // --- Stage 1: Frontend (UI, UX, accessibility, responsive design) ---
    sa_frontend [
        shape=box,
        prompt="You are Stage 1/6 (Frontend) in Dark Factory's web architecture review pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nExplore the codebase at $workspace and evaluate:\n- UI component architecture\n- State management patterns\n- Accessibility (WCAG compliance)\n- Responsive design approach\n- Client-side routing\n- Bundle size considerations\n- SSR/CSR strategy\n- Design system consistency\n\nIf not relevant to this issue, output: {\"findings\": [\"N/A - no frontend changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOtherwise, reference specific files and code from the workspace.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 2: Backend (API design, server architecture, business logic) ---
    sa_backend [
        shape=box,
        prompt="You are Stage 2/6 (Backend) in Dark Factory's web architecture review pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nExplore the codebase at $workspace and evaluate:\n- API design (REST/GraphQL patterns)\n- Server architecture and middleware\n- Business logic organization\n- Error handling and logging\n- Session management\n- Authentication flow\n\nIf not relevant to this issue, output: {\"findings\": [\"N/A - no backend changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOtherwise, reference specific files and code from the workspace.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 3: Database (data modeling, queries, migrations) ---
    sa_database_web [
        shape=box,
        prompt="You are Stage 3/6 (Database) in Dark Factory's web architecture review pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nExplore the codebase at $workspace and evaluate:\n- Data modeling and schema design\n- ORM usage and query patterns\n- Query optimization opportunities\n- Migration strategy\n- Indexing approach\n- Connection pooling\n- Caching layer (Redis/Memcached)\n- Data validation\n\nIf not relevant to this issue, output: {\"findings\": [\"N/A - no database changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOtherwise, reference specific files and code from the workspace.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 4: Security (auth, OWASP, XSS, CSRF, secrets) ---
    // CRITICAL: Reviews ALL prior recommendations
    sa_security_web [
        shape=box,
        prompt="You are Stage 4/6 (Security) in Dark Factory's web architecture review pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nCRITICAL: Review ALL prior stage recommendations for security implications.\n\nExplore the codebase at $workspace and evaluate:\n- Authentication/authorization patterns\n- OWASP top 10 compliance\n- XSS prevention (output encoding)\n- CSRF protection\n- CSP headers\n- Secrets management\n- Input validation at all boundaries\n- Rate limiting\n- CORS policy\n\nFor each concern, reference specific files and code from the workspace.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 5: Performance (load time, caching, optimization) ---
    sa_performance_web [
        shape=box,
        prompt="You are Stage 5/6 (Performance) in Dark Factory's web architecture review pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nExplore the codebase at $workspace and evaluate:\n- Page load time and Core Web Vitals\n- Caching strategy (CDN, browser, server)\n- Lazy loading and code splitting\n- Image optimization\n- Database query performance\n- API response time\n- Bundle size\n\nIf not relevant to this issue, output: {\"findings\": [\"N/A - no performance impact\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOtherwise, reference specific files and code from the workspace.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Stage 6: Integration (APIs, third-party services, deployment) ---
    sa_integration_web [
        shape=box,
        prompt="You are Stage 6/6 (Integration) in Dark Factory's web architecture review pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nExplore the codebase at $workspace and evaluate:\n- Third-party API integrations\n- Webhook handling\n- Email/notification services\n- Payment gateways (if applicable)\n- Analytics integration\n- CI/CD pipeline\n- Deployment strategy\n- Environment configuration\n\nIf not relevant to this issue, output: {\"findings\": [\"N/A - no integration changes\"], \"risk_level\": \"low\", \"recommendations\": [], \"approval\": true}\n\nOtherwise, reference specific files and code from the workspace.\n\nOutput your findings as structured JSON:\n{\"findings\": [...], \"risk_level\": \"low|medium|high|critical\", \"recommendations\": [...], \"approval\": true|false}"
    ]

    // --- Solutions Architect Lead (final synthesis) ---
    sa_lead_web [
        shape=box,
        prompt="You are the Solutions Architect performing final review of the web architecture pipeline.\n\nWorkspace: $workspace\nIssue: $issue\n\nYou have output from 6 specialist stages. Read their findings from the pipeline context.\n\nSynthesize all reviews into an Engineering Brief:\n- Approved architectural approach for the web application\n- Key constraints and risks identified across all domains\n- Implementation guidance per domain\n- Verdict: APPROVED | NEEDS_CHANGES | NEEDS_HUMAN\n\nIf critical stages (Backend, Security) found high/critical risks, consider NEEDS_HUMAN.\n\nWrite the Engineering Brief to: $workspace/.dark-factory/specs/$issue_number/engineering-brief.md\n\nOutput your verdict as the final line: APPROVED, NEEDS_CHANGES, or NEEDS_HUMAN"
    ]

    // --- Verdict ---
    verdict [shape=diamond, label="SA Verdict?"]
    approved [shape=Msquare, label="Engineering Brief\n(APPROVED)"]
    needs_human [shape=house, label="Human Review Required"]

    // --- Flow: Sequential ---
    start -> sa_frontend -> sa_backend -> sa_database_web
    sa_database_web -> sa_security_web -> sa_performance_web -> sa_integration_web
    sa_integration_web -> sa_lead_web -> verdict

    verdict -> approved [label="APPROVED"]
    verdict -> sa_frontend [label="NEEDS_CHANGES"]
    verdict -> needs_human [label="NEEDS_HUMAN"]
}
