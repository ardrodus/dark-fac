// Story TDD: Per-story Test-Driven Development loop
//
// Child pipeline for the dark_forge story_loop manager.
// Runs the TDD cycle for a single user story:
//   Test Writer -> Feature Writer -> Run Tests -> Code Review -> PR
//
// The manager (story_loop) iterates this pipeline once per story,
// with up to max_iterations retries if tests fail or review rejects.

digraph story_tdd {
    graph [
        goal="Implement a single user story via TDD: write tests, implement feature, validate, review"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Story Ready"]

    // --- Stage 1: Test Writer (isolated to tests/) ---
    test_writer [
        shape=box,
        prompt="You are the Test Writer. You have access ONLY to the tests/ directory.\n\nWrite failing tests for this user story:\n$current_story\n\nDesign contract:\n$gen_prd\n\nRules:\n- Write pytest tests that clearly express the acceptance criteria\n- Tests MUST fail (the feature doesn't exist yet)\n- Include edge cases and error scenarios\n- Do NOT implement any production code\n- Output test files only"
    ]

    // --- Stage 2: Feature Writer (isolated to src/, blind to tests) ---
    feature_writer [
        shape=box,
        prompt="You are the Feature Writer. You have access to src/ and lib/ ONLY.\nYou CANNOT see the test source code.\n\nImplement the feature for this user story:\n$current_story\n\nDesign artifacts:\n$gen_prd\n\nRules:\n- Implement against the design spec, NOT by reverse-engineering tests\n- Run pytest to validate (black-box, you see pass/fail only)\n- Production-quality code with proper error handling\n- Follow existing code conventions"
    ]

    // --- Run Tests ---
    run_tests [
        shape=parallelogram,
        label="pytest $test_files"
    ]
    tests_pass [shape=diamond, label="Tests Pass?"]

    // --- Stage 3: Code Reviewer (read-only) ---
    code_reviewer [
        shape=box,
        prompt="You are the Code Reviewer. You have READ-ONLY access to the entire repository.\n\nReview the implementation for:\n- Correctness against design spec\n- Code quality and conventions\n- Security vulnerabilities (OWASP top 10)\n- Error handling completeness\n- Test coverage adequacy\n\nProvide verdict: approved | changes_requested | human_review_required\nIf changes_requested, provide specific actionable feedback."
    ]
    review_verdict [shape=diamond, label="Review\nVerdict?"]

    // --- Feedback Loop ---
    feedback_check [shape=diamond, label="Rounds < 3?"]

    // --- Outputs ---
    create_pr [
        shape=parallelogram,
        label="gh pr create --title '$current_story.title' --body '$review_summary'"
    ]
    escalate [shape=house, label="Human Review Required"]
    done [shape=Msquare, label="PR Created"]

    // --- Flow ---
    start -> test_writer -> feature_writer -> run_tests -> tests_pass

    tests_pass -> code_reviewer [label="pass"]
    tests_pass -> feature_writer [label="fail (retry)"]

    code_reviewer -> review_verdict
    review_verdict -> create_pr [label="approved"]
    review_verdict -> feedback_check [label="changes_requested"]

    feedback_check -> feature_writer [label="yes"]
    feedback_check -> escalate [label="no (>=3 rounds)"]

    create_pr -> done
}
