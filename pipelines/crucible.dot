// Crucible: Two-Round Validation Pipeline with Test Graduation
//
// ARCHITECTURE: This DOT file IS the pipeline implementation.
// Python only does: resolve repo → acquire workspace → engine.run_pipeline("crucible").
// ALL workflow logic, branching, and decisions live HERE — not in Python.
// If you need to change Crucible's behavior, modify THIS file.
//
// The "bill becoming a law" pipeline:
//   1. Pull crucible repo + PR branch
//   2. Detect frameworks, install deps
//   3. Containerize app with digital twins
//   4. Generate scenario tests from PR diff
//   5. ROUND 1: Run new PR tests (smoke)
//   6. ROUND 2: Run all existing tests (regression)
//   7. Graduate new tests to crucible repo via PR
//
// Verdicts: GO | NO_GO | NEEDS_LIVE
//
// Flow: provision -> detect -> containerize -> generate -> smoke -> regress -> graduate
//
// Entry points: cli/dispatch.py → dispatch_test() or _run_crucible_interactive()
// Both follow: _resolve_active_repo() → acquire_workspace() → engine.run_pipeline()

digraph crucible {
    graph [
        goal="Validate PR via two-round testing then graduate new tests to crucible repo"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="PR Ready\n(merged to main or PR branch)"]

    // --- Phase 1: Provision ---
    clone_crucible [
        shape=parallelogram,
        label="Clone Crucible Repo",
        prompt="cd $workspace && git clone $test_repo .dark-factory/crucible-tests/ 2>&1 || git -C .dark-factory/crucible-tests/ pull --ff-only 2>&1",
        timeout="5m"
    ]

    clone_pr [
        shape=parallelogram,
        label="Clone PR Branch",
        prompt="cd $workspace && git fetch origin $pr_branch && git checkout $pr_branch 2>&1 || echo 'Already on PR branch'",
        timeout="3m"
    ]

    // --- Phase 2: Framework Detection ---
    detect_frameworks [
        shape=box,
        label="Framework Detection\nAgent",
        prompt="$eng_crucible_framework_agent\n\nExamine the target app at $workspace to determine which E2E/integration test frameworks are needed for Crucible validation.\n\nApp workspace: $workspace\nCrucible test repo: $workspace/.dark-factory/crucible-tests/\n\nIMPORTANT: Recommend SCENARIO/E2E frameworks, NOT unit test runners.\n- Web UI: Playwright (preferred), Cypress (NOT Jest or Mocha alone)\n- REST API: supertest (Node), httpx (Python) (NOT pytest alone)\n- pytest and Jest are test RUNNERS, not E2E frameworks\n\nAnalysis steps:\n1. Examine the app technology stack (language, framework, runtime)\n2. Identify testable surfaces: web UI, REST API, GraphQL, CLI, WebSocket\n3. For each surface, recommend ONE E2E/integration framework (max 3 total)\n4. Check what already exists in the crucible repo\n5. Install missing frameworks\n\nWrite detection results to: $workspace/.dark-factory/crucible/framework-detection.json"
    ]

    // --- Phase 3: Containerization + Twins ---
    containerize [
        shape=box,
        label="Containerize App\n+ Digital Twins",
        prompt="You are the Crucible containerization agent.\n\nWorkspace: $workspace\n\n1. Read the generated Dockerfile and docker-compose.yml in .dark-factory/generated/\n2. If digital twins are configured in .dark-factory/twins/, include them via compose merge\n3. Run: docker compose build\n4. Run: docker compose up -d\n5. Health-check all services (app + twins)\n6. Mount crucible tests into the container at /crucible/\n\nReport: HEALTHY if all services pass health checks, UNHEALTHY otherwise."
    ]

    health_check [shape=diamond, label="App\nHealthy?"]
    container_failed [shape=house, label="Container Failure\n-> Obelisk Triage"]

    // --- Phase 4: Scenario Generation ---
    generate_scenarios [
        shape=box,
        label="Scenario Test\nGeneration Agent",
        prompt="$eng_crucible_scenario_agent\n\nRead the PR diff and generate end-to-end scenario tests.\n\nWorkspace: $workspace\nPR number: $pr_number\nPR branch: $pr_branch\nBase SHA: $base_sha\nHead SHA: $head_sha\nCrucible tests: $workspace/.dark-factory/crucible-tests/\n\nSteps:\n1. Run: git diff $base_sha...$head_sha in $workspace\n2. Identify changed files, new endpoints, modified UI components\n3. Generate 1-5 test files using detected framework patterns\n4. Write to: crucible-tests/tests/pr-$pr_number-<feature>.spec.<ext>\n\nRules:\n- Each test exercises a USER-VISIBLE behavior change\n- Tests must be self-contained and deterministic\n- Use detected framework idioms\n- Max 500 lines total"
    ]

    // --- Phase 5: Round 1 -- Smoke (PR tests only) ---
    round1_smoke [
        shape=box,
        label="ROUND 1: Smoke\n(new PR tests only)",
        prompt="You are the Crucible smoke test runner.\n\nWorkspace: $workspace\nCrucible: $workspace/.dark-factory/crucible-tests/\nPR number: $pr_number\n\nRun ONLY the newly generated PR tests (files matching tests/pr-$pr_number-*).\nDo NOT run existing tests yet.\n\nFor each failure, classify as:\n- REAL_BUG: Genuine assertion failure on correct behavior\n- FLAKY: Timeout, element not found, race condition\n- ENV_ISSUE: Connection refused, missing service\n- NEEDS_LIVE: Requires external service not available\n\nVerdict: PASS (all tests pass or only FLAKY) | FAIL (any REAL_BUG)"
    ]

    smoke_verdict [shape=diamond, label="Smoke\nVerdict?"]
    smoke_failed [shape=house, label="NO_GO\nNew tests failed"]

    // --- Phase 6: Round 2 -- Full Regression ---
    round2_regression [
        shape=box,
        label="ROUND 2: Regression\n(all crucible tests)",
        prompt="You are the Crucible regression test runner.\n\nWorkspace: $workspace\nCrucible: $workspace/.dark-factory/crucible-tests/\n\nRun the FULL test suite: all existing crucible tests PLUS the new PR tests.\nThis validates the new tests do not break existing tests.\n\nClassify failures the same way as Round 1.\n\nVerdict:\n- PASS: All tests pass (>= 95% pass rate AND zero REAL_BUG)\n- FAIL: Any REAL_BUG found\n- NEEDS_LIVE: Tests require live services (zero REAL_BUG)"
    ]

    regression_verdict [shape=diamond, label="Regression\nVerdict?"]

    // --- Phase 7: Test Graduation ---
    graduate_tests [
        shape=box,
        label="Graduate Tests\n(PR to crucible repo)",
        prompt="$eng_crucible_graduation_agent\n\nTests passed both rounds — time to make them permanent.\n\nCrucible repo: $workspace/.dark-factory/crucible-tests/\nApp repo: $app_repo\nPR number: $pr_number\n\nSteps:\n1. Rename test files: remove 'pr-$pr_number-' prefix\n2. Check for naming conflicts with existing tests\n3. Create branch: crucible/graduate-pr-$pr_number\n4. Commit: 'feat(crucible): graduate tests from PR #$pr_number'\n5. Push and create PR to crucible repo\n\nThe bill becomes law."
    ]

    // --- Terminals ---
    go [shape=Msquare, label="GO\nAll tests pass\nNew tests graduated"]
    no_go [shape=Msquare, label="NO_GO\nRegression failure"]
    needs_live [shape=Msquare, label="NEEDS_LIVE\nRequires live services"]

    // --- Teardown ---
    teardown [
        shape=parallelogram,
        label="Teardown containers",
        prompt="cd $workspace && docker compose -p crucible down -v --remove-orphans 2>&1 || true",
        timeout="2m"
    ]

    // --- Flow ---
    start -> clone_crucible -> clone_pr -> detect_frameworks
    detect_frameworks -> containerize -> health_check

    health_check -> generate_scenarios [label="HEALTHY"]
    health_check -> container_failed [label="UNHEALTHY"]

    generate_scenarios -> round1_smoke -> smoke_verdict

    smoke_verdict -> round2_regression [label="PASS"]
    smoke_verdict -> smoke_failed [label="FAIL"]

    round2_regression -> regression_verdict

    regression_verdict -> graduate_tests [label="PASS"]
    regression_verdict -> no_go [label="FAIL"]
    regression_verdict -> needs_live [label="NEEDS_LIVE"]

    graduate_tests -> teardown -> go

    smoke_failed -> teardown
    no_go -> teardown
    needs_live -> teardown
}
