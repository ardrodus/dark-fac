// Crucible: Validation Pipeline
//
// Dark Factory's test validation layer. Runs the full test suite against
// a workspace and produces a three-way verdict:
//   GO        -- 95%+ pass rate AND zero real bugs detected
//   NO_GO     -- Any real bug found (test failure confirmed as genuine)
//   NEEDS_LIVE -- Tests require live/external services not available in CI
//
// Flow: clone tests -> security scan -> scope detection -> run + analyze -> verdict

digraph crucible {
    graph [
        goal="Validate workspace code via single test run with three-way verdict"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Workspace Ready\n(code under test)"]

    // --- Stage 1: Load Tests (git clone) ---
    load_tests [
        shape=parallelogram,
        label="Fetch test suite",
        prompt="cd $workspace && git clone $test_repo .dark-factory/crucible-tests/ 2>&1 || echo 'Test repo already cloned'",
        timeout="5m"
    ]

    // --- Stage 2: Sentinel Scan (Gate 1 on test code) ---
    sentinel_scan [
        shape=box,
        prompt="You are Sentinel performing Gate 1 on TEST CODE (not production code).\n\nWorkspace: $workspace\nTest directory: $workspace/.dark-factory/crucible-tests/\n\nScan the test suite for:\n- Embedded secrets or credentials in test fixtures\n- Malicious dependencies in test requirements\n- Shell injection or file-system escape in test helpers\n- Network calls to unexpected external hosts\n- Any attempt to modify code outside the test directory\n\nRead the test files and analyze them.\n\nVerdict: CLEAN (proceed) | BLOCK (test code is unsafe, abort pipeline)"
    ]
    sentinel_verdict [shape=diamond, label="Test Code\nSafe?"]
    sentinel_blocked [shape=house, label="BLOCK\nMalicious Test Code\n-> Security Triage"]

    // --- Stage 3: Detect Scope ---
    detect_scope [
        shape=box,
        prompt="You are the Crucible scope detector.\n\nWorkspace: $workspace\nBase SHA: $base_sha\nHead SHA: $head_sha\n\nAnalyze the test suite and workspace to determine test scope.\n\nDetect:\n- Test framework (pytest, jest, playwright, cargo test, go test, etc.)\n- Test files and count\n- Required services (databases, APIs, message queues)\n- Environment variables needed\n- Fixtures and setup requirements\n\nClassify each test as: unit | integration | e2e\nFlag tests that require live/external services not available in CI.\n\nWrite your detection results to: $workspace/.dark-factory/crucible/scope.json\nInclude: framework, test_count, run_command, live_service_tests[]"
    ]

    // --- Stage 4: Run Tests + Analyze ---
    // Agent node: reads scope detection output, runs the detected test framework,
    // then analyzes the results in one pass.
    run_and_analyze [
        shape=box,
        prompt="You are the Crucible test runner and analyst.\n\nWorkspace: $workspace\nBase SHA: $base_sha\nHead SHA: $head_sha\n\n## Step 1: Run Tests\n\nRead the scope detection results at: $workspace/.dark-factory/crucible/scope.json\nRun the detected test framework against the workspace.\nCapture the full test output.\n\n## Step 2: Analyze Results\n\nFor each test failure, classify as:\n- REAL_BUG: Genuine code defect (assertion on correct behavior fails)\n- FLAKY: Non-deterministic failure (timing, ordering, resource contention)\n- ENV_ISSUE: Missing service, config, or dependency (not a code bug)\n- NEEDS_LIVE: Requires live external service unavailable in CI\n\nCompute pass rate: passed / (passed + failed) * 100\n\nWrite analysis to: $workspace/.dark-factory/crucible/analysis.json\nInclude: pass_rate, real_bug_count, needs_live_count, failure_details[]\n\nOutput a summary with your verdict recommendation:\n- GO: pass_rate >= 95% AND real_bug_count == 0\n- NO_GO: real_bug_count > 0\n- NEEDS_LIVE: needs_live_count > 0 AND real_bug_count == 0"
    ]

    // --- Stage 5: Verdict (three-way) ---
    verdict [shape=diamond, label="Verdict?"]

    go [shape=Msquare, label="GO\n95%+ pass rate\nzero real bugs"]
    no_go [shape=Msquare, label="NO_GO\nreal bug detected"]
    needs_live [shape=Msquare, label="NEEDS_LIVE\nrequires live services"]

    // --- Flow ---
    start -> load_tests -> sentinel_scan -> sentinel_verdict

    sentinel_verdict -> detect_scope [label="CLEAN"]
    sentinel_verdict -> sentinel_blocked [label="BLOCK"]

    detect_scope -> run_and_analyze -> verdict

    verdict -> go [label="pass >= 95%\nreal_bugs == 0"]
    verdict -> no_go [label="real_bugs > 0"]
    verdict -> needs_live [label="needs_live > 0\nreal_bugs == 0"]
}
