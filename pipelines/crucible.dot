// Crucible: Scenario-Based Validation Pipeline with Test Graduation
//
// ARCHITECTURE: This DOT file IS the pipeline implementation.
// Python only does: resolve repo → acquire workspace → engine.run_pipeline("crucible").
// ALL workflow logic, branching, and decisions live HERE — not in Python.
// If you need to change Crucible's behavior, modify THIS file.
//
// The "bill becoming a law" pipeline — scenario tests are NATURAL LANGUAGE
// PROMPTS, not code. The LLM agent reads a .scenario file, uses bash/curl
// to execute it against the running app, and reports PASS/FAIL.
//
// Two paths based on app type:
//
//   WEB apps (app_type=web):
//     provision → containerize → health check → run scenarios → graduate
//     Agent tests via HTTP from the host (curl/httpx against localhost:port)
//
//   CONSOLE apps (app_type=console):
//     provision → run scenarios → graduate
//     Agent runs the binary directly in the workspace (no Docker)
//
// No test frameworks. No Playwright. No framework detection.
// The LLM + bash + curl IS the test harness.
//
// Scenario files live in the crucible companion repo, organized by feature:
//   crucible-tests/
//     scenarios/
//       auth/
//         login.scenario             ← permanent (graduated)
//       cart/
//         checkout.scenario          ← permanent (graduated)
//       pr-42-new-endpoint.scenario  ← new, pending graduation
//
// The agent traverses scenarios/ recursively to find ALL *.scenario files.
//
// Each .scenario file is a natural language prompt describing what to test.
// The LLM agent reads it, executes the steps using tools, and reports results.
//
// Verdicts: GO | NO_GO | NEEDS_LIVE
//
// Entry points: cli/dispatch.py → dispatch_test() or _run_crucible_interactive()
// Both follow: _resolve_active_repo() → acquire_workspace() → engine.run_pipeline()
//
// Context variables (set by dispatch):
//   $workspace    — path to the app workspace
//   $test_repo    — HTTPS clone URL for the crucible companion test repo
//   $pr_number    — PR number being validated
//   $pr_branch    — branch name for the PR
//   $app_type     — "web" or "console" (from workspace_config)
//   $language     — primary language (from analysis)
//   $framework    — framework if any (from analysis)
//
// Node shapes: box = LLM agent, parallelogram = shell, diamond = decision,
//              house = terminal (non-exit), Mdiamond = start, Msquare = exit

digraph crucible {
    graph [
        goal="Validate PR via scenario-based testing then graduate new scenarios to crucible repo"
    ]

    // =============================================
    // PHASE 1: PROVISION
    // =============================================

    start [shape=Mdiamond, label="PR Ready"]

    clone_crucible [
        shape=parallelogram,
        label="Clone Crucible Repo",
        prompt="cd $workspace && git clone $test_repo .dark-factory/crucible-tests/ 2>&1 || git -C .dark-factory/crucible-tests/ pull --ff-only 2>&1",
        timeout="5m"
    ]

    clone_pr [
        shape=parallelogram,
        label="Checkout PR Branch",
        prompt="cd $workspace && git fetch origin $pr_branch && git checkout $pr_branch 2>&1 || echo 'Already on PR branch'",
        timeout="3m"
    ]

    // =============================================
    // PHASE 2: INVENTORY
    // =============================================

    inventory_scenarios [
        shape=parallelogram,
        label="Inventory Scenarios",
        prompt="python -m dark_factory.crucible.inventory $workspace/.dark-factory/crucible-tests/ 2>&1",
        timeout="1m"
    ]

    reinventory [
        shape=parallelogram,
        label="Re-inventory Scenarios",
        prompt="python -m dark_factory.crucible.inventory $workspace/.dark-factory/crucible-tests/ 2>&1",
        timeout="1m"
    ]

    // =============================================
    // PHASE 3: ENVIRONMENT SETUP (split by app type)
    // =============================================

    app_type_check [shape=diamond, label="App Type?"]

    // --- Web path: containerize the app ---

    generate_dockerfile [
        shape=box,
        label="Generate Dockerfile",
        prompt="You are the Crucible containerization agent.\n\nWorkspace: $workspace\nLanguage: $language\nFramework: $framework\n\nGenerate Docker files to run the app and its dependencies:\n\n1. Read the project structure, package files, and any existing Dockerfile\n2. Generate $workspace/.dark-factory/crucible/Dockerfile:\n   - Use an appropriate base image for $language\n   - Install project dependencies\n   - Copy source code\n   - Set the entrypoint to start the app\n3. Generate $workspace/.dark-factory/crucible/docker-compose.yml:\n   - App service from the Dockerfile above\n   - If the app uses a database (check for ORM configs, connection strings):\n     add a database service (postgres, mysql, redis, etc.) as a digital twin\n   - Expose relevant ports\n   - Health check for the app service\n4. Write the exposed port number to: $workspace/.dark-factory/crucible/app-port.txt\n\nOutput: READY"
    ]

    containerize [
        shape=parallelogram,
        label="Build + Start Containers",
        prompt="cd $workspace && docker compose -f .dark-factory/crucible/docker-compose.yml -p crucible build && docker compose -f .dark-factory/crucible/docker-compose.yml -p crucible up -d --wait 2>&1",
        timeout="10m"
    ]

    health_check [shape=diamond, label="Containers\nHealthy?"]
    container_failed [shape=house, label="Container Failure"]

    // =============================================
    // PHASE 3: SCENARIO GENERATION
    // (both paths converge here)
    // =============================================

    generate_scenarios [
        shape=box,
        label="Generate Scenarios\nfor PR changes",
        prompt="You are the Crucible scenario generation agent.\n\nWorkspace: $workspace\nApp type: $app_type\nLanguage: $language\nFramework: $framework\nPR number: $pr_number\nPR branch: $pr_branch\nCrucible tests: $workspace/.dark-factory/crucible-tests/\n\nGenerate natural language scenario files that validate the PR's changes.\n\nSteps:\n1. Run: cd $workspace && git diff origin/main...$pr_branch -- . ':!.dark-factory'\n2. Identify changed files, new endpoints, modified CLI commands, new features\n3. For each testable change, write a .scenario file:\n\n   For WEB apps:\n   - Scenarios exercise HTTP endpoints from the host\n   - Example: 'POST /api/cart/add with body {\"item_id\": 42}. Expect 200.'\n   - Test response codes, JSON shapes, error handling\n   - Reference localhost:<port> (read port from $workspace/.dark-factory/crucible/app-port.txt)\n\n   For CONSOLE apps:\n   - Scenarios run the binary directly\n   - Example: 'Run ./myapp --version. Expect output containing a semver string.'\n   - Test CLI flags, stdout/stderr, exit codes, file output\n\n4. Write to: $workspace/.dark-factory/crucible-tests/scenarios/pr-$pr_number-<feature>.scenario\n   (new PR scenarios go in the scenarios/ root, NOT in feature subdirs)\n\nRules:\n- Each scenario tests ONE user-visible behavior from the PR\n- Scenarios are plain English instructions — NOT code\n- Include expected outcomes (status codes, output patterns, file existence)\n- Max 10 scenarios per PR\n- Keep each scenario under 20 lines\n\nOutput: GENERATED"
    ]

    // =============================================
    // PHASE 4: ROUND 1 — SMOKE (new PR scenarios only)
    // =============================================

    round1_smoke [
        shape=box,
        label="ROUND 1: Smoke\n(new PR scenarios only)",
        prompt="You are the Crucible smoke test agent.\n\nWorkspace: $workspace\nApp type: $app_type\nPR number: $pr_number\nScenarios: $workspace/.dark-factory/crucible-tests/scenarios/\n\nExecute ONLY the newly generated PR scenarios.\nRead the manifest: $workspace/.dark-factory/crucible-tests/scenario-manifest.json\nThe 'pr' array lists all new PR scenarios with their paths.\nDo NOT run existing (graduated) scenarios yet.\n\nFor each scenario file:\n1. Read the natural language instructions\n2. Execute them using bash commands (curl, httpx, the app binary, etc.)\n3. Compare actual results against expected outcomes in the scenario\n4. Record PASS or FAIL with details\n\nFor WEB apps: use curl/httpx against localhost:<port> from the host.\nFor CONSOLE apps: run commands directly in $workspace.\n\nFor each failure, classify as:\n- REAL_BUG: Actual behavior doesn't match expected (assertion failure)\n- ENV_ISSUE: Connection refused, service unavailable, timeout\n- NEEDS_LIVE: Requires external service not available locally\n\nWrite results to: $workspace/.dark-factory/crucible/smoke-results.json\nFormat: {scenarios: [{file, verdict, classification, detail}], summary: {pass, fail, total}}\n\nOutput verdict as final line: PASS (all pass) | FAIL (any REAL_BUG) | NEEDS_LIVE"
    ]

    smoke_verdict [shape=diamond, label="Smoke?"]
    smoke_failed [shape=house, label="NO_GO\nSmoke failed"]

    // =============================================
    // PHASE 5: ROUND 2 — FULL REGRESSION
    // =============================================

    round2_regression [
        shape=box,
        label="ROUND 2: Regression\n(all scenarios)",
        prompt="You are the Crucible regression test agent.\n\nWorkspace: $workspace\nApp type: $app_type\nScenarios: $workspace/.dark-factory/crucible-tests/scenarios/\n\nExecute ALL scenario files — both graduated and new PR scenarios.\nRead the manifest: $workspace/.dark-factory/crucible-tests/scenario-manifest.json\nRun every scenario listed in both the 'graduated' and 'pr' arrays.\nThis validates the PR doesn't break existing behavior.\n\nFor each scenario file:\n1. Read the natural language instructions\n2. Execute them using bash commands\n3. Compare actual results against expected outcomes\n4. Record PASS or FAIL with details\n\nClassify failures the same way as Round 1.\n\nWrite results to: $workspace/.dark-factory/crucible/regression-results.json\nFormat: {scenarios: [{file, verdict, classification, detail}], summary: {pass, fail, total}}\n\nOutput verdict as final line:\n- PASS: All pass (>= 95% pass rate AND zero REAL_BUG)\n- FAIL: Any REAL_BUG found\n- NEEDS_LIVE: Tests require live services (zero REAL_BUG)"
    ]

    regression_verdict [shape=diamond, label="Regression?"]

    // =============================================
    // PHASE 6: TEARDOWN + GRADUATION
    // =============================================

    teardown [
        shape=parallelogram,
        label="Teardown containers",
        prompt="cd $workspace && docker compose -f .dark-factory/crucible/docker-compose.yml -p crucible down -v --remove-orphans 2>&1 || true",
        timeout="2m"
    ]

    graduate_scenarios [
        shape=box,
        label="Graduate Scenarios\n(PR to crucible repo)",
        prompt="You are the Crucible graduation agent.\n\nCrucible repo: $workspace/.dark-factory/crucible-tests/\nPR number: $pr_number\n\nScenarios passed both rounds — time to make them permanent.\n\nSteps:\n1. Find new scenarios: find $workspace/.dark-factory/crucible-tests/scenarios/ -maxdepth 1 -name 'pr-$pr_number-*.scenario'\n2. For each, decide the best feature subdirectory (create if needed)\n3. Move and rename: strip 'pr-$pr_number-' prefix, place in feature dir\n   (e.g. scenarios/pr-42-new-endpoint.scenario → scenarios/api/new-endpoint.scenario)\n4. Check for naming conflicts with existing scenarios\n4. cd $workspace/.dark-factory/crucible-tests/\n5. git checkout -b crucible/graduate-pr-$pr_number\n6. git add -A && git commit -m 'feat(crucible): graduate scenarios from PR #$pr_number'\n7. git push -u origin crucible/graduate-pr-$pr_number\n8. gh pr create --title 'crucible: graduate PR #$pr_number scenarios' --label crucible-passed\n\nThe bill becomes law.\n\nOutput: GO"
    ]

    // =============================================
    // TERMINALS
    // =============================================

    go [shape=Msquare, label="GO"]
    no_go [shape=Msquare, label="NO_GO"]
    needs_live [shape=Msquare, label="NEEDS_LIVE"]

    // =============================================
    // FLOW
    // =============================================

    // Provision + inventory
    start -> clone_crucible -> clone_pr -> inventory_scenarios -> app_type_check

    // Split by app type
    app_type_check -> generate_dockerfile [label="WEB"]
    app_type_check -> generate_scenarios [label="CONSOLE"]

    // Web path: dockerfile → build → health check → scenarios
    generate_dockerfile -> containerize -> health_check
    health_check -> generate_scenarios [label="PASS"]
    health_check -> container_failed [label="FAIL"]

    // Both paths converge: generate → re-inventory → smoke → regression
    generate_scenarios -> reinventory -> round1_smoke -> smoke_verdict
    smoke_verdict -> round2_regression [label="PASS"]
    smoke_verdict -> smoke_failed [label="FAIL"]

    round2_regression -> regression_verdict
    regression_verdict -> graduate_scenarios [label="PASS"]
    regression_verdict -> no_go [label="FAIL"]
    regression_verdict -> needs_live [label="NEEDS_LIVE"]

    // Graduate then done (web tears down containers first)
    graduate_scenarios -> teardown -> go

    // Failure paths also teardown containers (no-op for console)
    smoke_failed -> teardown
    no_go -> teardown
    needs_live -> teardown
    container_failed -> teardown
}
