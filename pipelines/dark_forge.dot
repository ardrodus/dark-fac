// Dark Forge: TDD Pipeline
//
// ARCHITECTURE: This DOT file IS the pipeline implementation.
// Python only does: resolve repo → acquire workspace → engine.run_pipeline("dark_forge").
// ALL workflow logic, branching, and decisions live HERE — not in Python.
// If you need to change Dark Forge's behavior, modify THIS file.
//
// The build engine of Dark Factory. Takes an approved issue through
// spec generation, PRD splitting, and agent-driven TDD execution.
//
// Flow:
//   1. Spec generation: design → api → schema → interfaces → test strategy
//   2. gen_prd: separates specs into test + feature, generates PRD JSON for each
//   3. test_writer: agent implements tests from test PRD
//   4. feature_writer: agent implements features from feature PRD, then fix loop
//
// Entry point: cli/dispatch.py → _run_forge_interactive()
// Follows: _resolve_active_repo() → acquire_workspace() → engine.run_pipeline()

digraph dark_forge {
    graph [
        goal="Transform an approved GitHub issue into merged PRs via spec generation + TDD"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Approved Issue"]

    // ===========================================
    // Issue Interpretation
    //
    // Translates the raw issue into a clear feature scope so
    // downstream agents evaluate the right thing.
    // ===========================================

    interpret_issue [
        shape=box,
        prompt="You are:\n$issue_interpreter_agent\n\nIssue:\n$issue\n\nWorkspace: $workspace\n\nExplore $workspace to understand the codebase structure and identify what parts are relevant to this issue.\n\nProduce a feature scope following the format in your instructions.\n\nWrite the feature scope to: $workspace/.dark-factory/specs/$issue_number/feature-scope.md\n\nAlso output the full feature scope as your response."
    ]

    // ===========================================
    // Architecture Review (external pipeline)
    // Currently bypassed for dev testing.
    // ===========================================

    arch_review [
        shape=hexagon,
        label="Architecture Review\n(app-type-selected pipeline)",
        child_graph="arch_review_${app_type}.dot",
        max_iterations=2,
        max_retries=2
    ]

    arch_verdict [shape=diamond, label="SA Verdict?"]
    arch_needs_human [shape=house, label="Human Arch Review Required"]

    // ===========================================
    // Specification Generation
    //
    // Sequential spec pipeline: each step builds on the previous.
    // All specs saved to .dark-factory/specs/{issue_number}/
    // ===========================================

    gen_design [
        shape=box,
        prompt="You are:\n$design_agent\n\nIssue:\n$issue\n\nWorkspace: $workspace\n\nGenerate a Technical Design Document for the feature described in the issue.\n\nExplore $workspace to understand existing patterns, frameworks, and conventions.\nYour design must work within the existing codebase — do not invent dependencies.\n\nCover:\n- Architecture decisions (with rationale)\n- Component changes (new/modified/removed) — name exact files\n- Data model changes (or state 'none')\n- API changes (or state 'none')\n- Risks and mitigations\n\nWrite output to .dark-factory/specs/$issue_number/design.md"
    ]

    gen_api_contract [
        shape=box,
        prompt="You are the API Contract Generator.\n\nRead the technical design document at: $gen_design_path\n\nAuto-detect the contract type from the codebase at $workspace:\n- OpenAPI for REST APIs\n- GraphQL schema for GraphQL\n- Protobuf for gRPC\n- CLI spec for command-line tools\n\nGenerate the appropriate contract spec with endpoints, request/response schemas, error codes.\nWrite output to .dark-factory/specs/$issue_number/api-contract.yaml"
    ]

    gen_schema [
        shape=box,
        prompt="You are the Schema Generator.\n\nRead the technical design document at: $gen_design_path\n\nDetect the database type from the codebase at $workspace (PostgreSQL, MySQL, SQLite, MongoDB, etc.).\nGenerate:\n- DDL for new tables/columns\n- Migration scripts for changes\n- Index recommendations\n\nWrite output to .dark-factory/specs/$issue_number/schema.sql"
    ]

    gen_interfaces [
        shape=box,
        prompt="You are the Interface Generator.\n\nRead the technical design document at: $gen_design_path\n\nGenerate language-appropriate typed interface definitions:\n- TypeScript: interfaces/types\n- Python: Protocol classes\n- Go: interfaces\n- Rust: traits\n- Java: interfaces\n\nDetect the language from the codebase at $workspace.\nWrite output to .dark-factory/specs/$issue_number/interfaces/"
    ]

    gen_test_strategy [
        shape=box,
        prompt="You are the Test Strategy Generator.\n\nWorkspace: $workspace\n\nRead these artifacts:\n- Design: $gen_design_path\n- API Contract: $gen_api_contract_path\n- Schema: $gen_schema_path\n- Interfaces: $gen_interfaces_path\n\nExplore the existing test suite in $workspace to understand current patterns.\n\nGenerate a test strategy covering:\n- Unit tests: what to test, expected assertions\n- Integration tests: component interactions\n- E2E tests: user-facing flows\n- Fixtures and mocks needed\n- Coverage targets\n- Existing tests that may be affected\n\nWrite output to .dark-factory/specs/$issue_number/test-strategy.md"
    ]

    // ===========================================
    // PRD Generation -- Separates into Test + Feature PRDs
    //
    // Reads all spec artifacts, separates test vs feature concerns,
    // then generates PRD JSON for each:
    //   tasks/test-prd.json    -- test PRD (stories for test writer)
    //   tasks/feature-prd.json -- feature PRD (stories for feature writer)
    // ===========================================

    gen_prd [
        shape=box,
        prompt="You are the PRD Generator. Your workspace is: $workspace\n\nGitHub Issue:\n$issue\n\nRead all technical spec artifacts:\n- Design: $gen_design_path\n- API Contract: $gen_api_contract_path\n- Schema: $gen_schema_path\n- Interfaces: $gen_interfaces_path\n- Test Strategy: $gen_test_strategy_path\n\nYou must perform these steps:\n\n## Step 1: Separate test vs feature concerns\n\nCreate TWO spec documents:\n- .dark-factory/specs/$issue_number/test-spec.md -- all test-related content: test strategy, acceptance criteria, test cases, fixtures, mocks, coverage targets, edge cases.\n- .dark-factory/specs/$issue_number/feature-spec.md -- all feature/implementation content: architecture, component changes, API endpoints, database schema, interfaces, implementation steps.\n\nBoth documents must be complete and self-contained.\n\n## Step 2: Generate PRD JSON files\n\nFor EACH spec document (test-spec.md and feature-spec.md):\n1. If the document is larger than 22KB, split it into 22KB chunk files under .dark-factory/specs/$issue_number/chunks/test/ (or chunks/feature/)\n2. For each chunk (or the whole doc if small enough), generate a PRD JSON with user stories, acceptance criteria, and dependencies\n3. Merge all chunk PRDs into a single master PRD JSON\n\nWrite the final PRD files to:\n- .dark-factory/specs/$issue_number/tasks/test-prd.json\n- .dark-factory/specs/$issue_number/tasks/feature-prd.json\n\nOutput a summary of what you created (file paths and story counts)."
    ]

    // ===========================================
    // Execution: TDD — Tests first, then features, then fix loop
    //
    // 1. test_writer: agent implements all tests from test PRD
    // 2. feature_writer: agent implements features from feature PRD (first pass)
    // 3. feature_fix_loop: iterates — analyze failures, create targeted fix PRD,
    //    agent fixes only what's broken. Exits when all tests pass.
    // ===========================================

    test_writer [
        shape=box,
        label="Test Writer",
        prompt="You are the Test Writer agent.\n\nWorkspace: $workspace\n\nRead the test PRD at: $workspace/.dark-factory/specs/$issue_number/tasks/test-prd.json\n\nThis PRD contains user stories describing tests to write. For each story, in dependency order:\n\n1. Read the story title, description, and acceptance criteria\n2. Explore the existing codebase at $workspace to understand the modules being tested\n3. Write the test files following existing test patterns and conventions in $workspace/tests/\n4. Ensure each acceptance criterion is covered by at least one test assertion\n\nDo NOT write implementation code — only test code.\nDo NOT modify existing tests unless a story explicitly requires it.\n\nAfter completing all stories, run: cd $workspace && python -m pytest tests/ --collect-only 2>&1\n\nOutput a summary of files created and test count."
    ]

    feature_writer [
        shape=box,
        label="Feature Writer",
        prompt="You are the Feature Writer agent.\n\nWorkspace: $workspace\n\nRead the feature PRD at: $workspace/.dark-factory/specs/$issue_number/tasks/feature-prd.json\nRead the original issue scope at: $workspace/.dark-factory/specs/$issue_number/feature-scope.md\nRead the technical design at: $workspace/.dark-factory/specs/$issue_number/design.md\n\nThis PRD contains user stories describing features to implement. For each story, in dependency order:\n\n1. Read the story title, description, and acceptance criteria\n2. Explore the existing codebase at $workspace to understand current patterns and conventions\n3. Implement the feature following existing code style and architecture\n4. Ensure each acceptance criterion is addressed by the implementation\n\n## CRITICAL: Integration Requirement\n\nYour job is NOT done when helper functions, utilities, or modules are created. You MUST wire new code into the existing application so the feature is actually visible and functional to the end user.\n\nFor EVERY new function, class, or module you create, verify:\n- Is it imported and called from the appropriate existing code path?\n- Does the existing application flow actually USE this new code?\n- Would a user running the application see the change?\n\nIf the answer to any of these is NO, you must also modify the existing calling code to integrate the new functionality. Creating standalone helpers that nothing calls is an incomplete implementation.\n\nCommon integration points to check:\n- CLI entry points and command handlers\n- Orchestrators and workflow controllers\n- Route handlers and controllers\n- Main application loops\n- Configuration initialization\n\nRead the design document to understand WHERE new code should be called from, not just what new code to write.\n\nDo NOT modify files under tests/ — only implement feature/production code.\n\n## CRITICAL: Clean Up Ad-Hoc Artifacts\n\nBefore finishing, you MUST remove any throwaway scripts, ad-hoc tools, temporary files, scratch modules, or other artifacts that were created during the process of writing this feature but are NOT part of the delivered feature itself. These include but are not limited to:\n- One-off debug or exploration scripts (e.g., try_*.py, scratch_*.py, debug_*.py)\n- Temporary data files, fixture dumps, or sample outputs used during development\n- Helper scripts written to test an idea that are not part of the final implementation\n- Any file you created that is not imported, referenced, or required by the production codebase\n\nThe repository must contain ONLY production code and intentional project files when you are done. Do NOT leave development debris behind.\n\nAfter completing all stories, run: cd $workspace && python -m pytest tests/ -x --tb=short 2>&1\n\nOutput a summary that includes:\n- Files created (new modules, helpers, etc.)\n- Files modified for integration (existing code that now calls the new code)\n- How the feature is now accessible to end users\n- Any ad-hoc artifacts that were cleaned up\n- Test results"
    ]

    feature_fix_loop [
        shape=hexagon,
        label="Fix Loop\n(targeted fixes until tests pass)",
        child_graph="feature_tdd.dot",
        max_iterations=10,
        success_condition="status=completed"
    ]

    // ===========================================
    // Diff Validation — verify changes address the issue
    //
    // Before creating a PR, validate that the workspace diff is
    // actually relevant to the issue. Prevents garbage PRs from
    // stale workspace state or failed spec generation.
    // ===========================================

    validate_diff [
        shape=box,
        prompt="You are the Dark Forge diff validator.\n\nWorkspace: $workspace\nIssue: $issue\n\nBefore creating a PR, validate that the changes actually address the issue.\n\n1. Run: cd $workspace && git diff --stat\n2. Run: cd $workspace && git diff\n3. Read the issue title and description\n4. For each changed file, assess: does this change contribute to solving the issue?\n5. If the diff is empty, or contains only unrelated changes (internal artifacts, infrastructure, files not mentioned in specs), output IRRELEVANT\n6. If the diff contains meaningful implementation changes that address the issue, output RELEVANT\n\nOutput the single word: RELEVANT or IRRELEVANT"
    ]

    diff_verdict [shape=diamond, label="Diff\nRelevant?"]

    // On IRRELEVANT: check retry count, either loop back or escalate.
    retry_or_escalate [
        shape=box,
        prompt="You are the Dark Forge retry controller.\n\nWorkspace: $workspace\nIssue: $issue\n\nThe diff validation found the changes do not address the issue.\n\nCheck the retry marker at: $workspace/.dark-factory/specs/$issue_number/retry-count.txt\n\n- If the file does not exist or contains '0': This is the first failure.\n  Write '1' to the retry marker file.\n  Reset the workspace: cd $workspace && git checkout -- . && git clean -fd\n  Output the single word: RETRY\n\n- If the file contains '1' or higher: This is the second failure.\n  Post a comment on the GitHub issue explaining that Dark Factory attempted\n  to solve the issue twice but could not produce relevant code changes.\n  Include what the pipeline tried (read specs from $workspace/.dark-factory/specs/$issue_number/)\n  and why the diff was irrelevant.\n  Run: gh issue comment $issue_number --body '<explanation>'\n  Output the single word: ESCALATED"
    ]

    retry_verdict [shape=diamond, label="Retry or\nEscalate?"]
    forge_failed [shape=house, label="Human Review\n(forge could not solve issue)"]

    // --- PR Creation ---
    create_pr [
        shape=box,
        prompt="You are the PR creation agent.\n\nWorkspace: $workspace\nIssue: $issue\n\nAll tests pass and the diff has been validated as relevant. Create a pull request.\n\n1. Run: cd $workspace && git diff --name-only to see what changed\n2. Review each changed file — only stage files that implement the feature or fix for issue #$issue_number\n3. Do NOT stage files under .dark-factory/ (these are internal pipeline artifacts)\n4. Do NOT stage files unrelated to the issue\n5. Stage only relevant files: git add <file1> <file2> ...\n6. Create a clear commit: git commit -m 'feat: <description> (#$issue_number)'\n7. Push to a feature branch:\n   git checkout -b feature/$issue_number\n   git push -u origin feature/$issue_number\n8. Create a PR with:\n   - Title referencing the issue\n   - Summary of changes (design decisions, files modified, test coverage)\n   - Link to the original issue\n   - Label: dark-forge\n\nRun in $workspace:\n  gh pr create --title '<description> (#$issue_number)' --label dark-forge\n\nOutput the PR URL."
    ]

    done [shape=Msquare, label="PR Created"]

    // --- Flow ---
    // Issue interpretation, then arch review, spec generation, TDD execution
    start -> interpret_issue -> arch_review -> arch_verdict
    arch_verdict -> gen_design [label="APPROVED"]
    arch_verdict -> arch_needs_human [label="NEEDS_HUMAN"]

    // Spec generation
    gen_design -> gen_api_contract -> gen_schema -> gen_interfaces -> gen_test_strategy -> gen_prd

    // Execute: tests first, full feature pass, targeted fix loop
    gen_prd -> test_writer -> feature_writer -> feature_fix_loop

    // Diff validation: verify changes address the issue before PR
    feature_fix_loop -> validate_diff -> diff_verdict
    diff_verdict -> create_pr [label="RELEVANT"]
    diff_verdict -> retry_or_escalate [label="IRRELEVANT"]
    retry_or_escalate -> retry_verdict
    retry_verdict -> gen_design [label="RETRY"]
    retry_verdict -> forge_failed [label="ESCALATED"]

    create_pr -> done
}
