// Sentinel: Security Gate Pipeline
//
// Dark Factory's security layer. Runs 5 gates at different pipeline points:
//   Gate 1  -- Post-clone: secret scan + dependency audit (blocks before any code runs)
//   Gate 2  -- Post-architecture/pre-TDD: dependency re-scan + SAST + SBOM
//   Gate 3  -- Pre-container: network isolation + container image scan
//   Gate 4  -- Pre-PR: incremental secret scan on diff
//   Gate 5  -- Post-review/pre-PR: AI security review of diff
//
// Sentinel is NOT called as one big pipeline. Each gate is invoked independently
// by Dark Factory at the appropriate lifecycle point. This DOT file describes
// the full gate sequence for documentation and visualization.
//
// ── Invocation Path ──────────────────────────────────────────────
//
// Sentinel nodes invoke factory/gates/*.py (thin wrappers), NOT
// factory/security/*.py directly.  Each gate wrapper re-exports
// GATE_NAME + create_runner from its security counterpart:
//
//   sentinel.dot node          factory/gates/ wrapper         factory/security/ impl
//   ─────────────────────────  ─────────────────────────────  ──────────────────────────────
//   secret_scan_full/incr  ->  gates/secret_scan.py       ->  security/secret_scan.py
//   dep_scan / dep_rescan  ->  gates/dependency_scan.py   ->  security/dependency_scan.py
//   sast_layer1            ->  gates/sast_scan.py         ->  security/sast_scan.py
//   sbom_generate          ->  gates/sbom_scan.py         ->  security/sbom_scan.py
//   image_scan             ->  gates/image_scan.py        ->  security/image_scan.py
//   security_review        ->  gates/ai_security_review.py -> security/ai_security_review.py
//   netiso_scan            ->  (AI prompt node)              security/network_isolation.py
//
// All security gates are registered in GATE_REGISTRY (framework.py)
// and can be run individually via run_gate_by_name() or discovered
// via discover_gates().
//
// Scan modes (configurable per repo):
//   strict   -- All HIGH+ findings block
//   standard -- CRITICAL blocks, HIGH warns (default)
//   audit    -- Nothing blocks, everything logged
//
// On BLOCK: finding routes to security triage. Human must respond:
//   fix_it | suppress | ignore_run | abort
//
// Demonstrates: sequential gates, conditional severity routing,
// human escalation, configurable scan modes.

digraph sentinel {
    graph [
        goal="Enforce security gates across the full Dark Factory pipeline lifecycle"
    ]

    // =============================================
    // GATE 1 -- Post-Clone (runs after workspace acquisition)
    // =============================================

    gate1_start [shape=Mdiamond, label="Workspace Acquired\n(repo cloned)"]

    // Gate 1a: Secret Scan (gitleaks + trufflehog)
    secret_scan_full [
        shape=parallelogram,
        label="gitleaks detect --source $workspace\ntrufflehog filesystem $workspace"
    ]
    secret_classify [
        shape=box,
        prompt="Classify secret scan findings by severity:\n$scan_results\n\n- CRITICAL: Active credentials (API keys, tokens, passwords with high entropy)\n- WARNING: Low-confidence patterns (base64 blobs, config values that look like keys)\n- INFO: Test/example secrets (in test fixtures, .env.example, mock data)\n\nFor each CRITICAL finding, recommend: rotation required, rotation recommended, or investigation needed.\nOutput structured JSON with severity, file, line, finding type, recommendation."
    ]
    secret_verdict [shape=diamond, label="Secrets\nFound?"]
    secret_blocked [shape=house, label="BLOCK\nCritical Secrets\n-> Security Triage"]

    // Gate 1b: Dependency Vulnerability Scan (npm audit / pip-audit / cargo audit)
    dep_scan [
        shape=parallelogram,
        label="npm audit / pip-audit / cargo audit\n(language-auto-detected)"
    ]
    dep_classify [
        shape=box,
        prompt="Analyze dependency vulnerability scan results:\n$dep_results\n\nClassify each vulnerability:\n- CRITICAL (CVSS >= 9.0): Known exploited, remote code execution, auth bypass\n- HIGH (CVSS 7.0-8.9): Significant but requires specific conditions\n- MEDIUM/LOW: Log only\n\nCheck for dependency confusion attacks (private package name squatting).\nOutput: severity, package, version, CVE, CVSS, recommendation (upgrade/patch/replace)."
    ]
    dep_verdict [shape=diamond, label="Critical\nDeps?"]
    dep_blocked [shape=house, label="BLOCK\nCritical CVEs\n-> Security Triage"]

    gate1_pass [shape=Msquare, label="Gate 1 PASS\n-> Architecture Review"]

    // =============================================
    // GATE 2 -- Post-Architecture / Pre-TDD
    // =============================================

    gate2_start [shape=Mdiamond, label="Architecture Approved\n(engineering brief ready)"]

    // Gate 2a: Dependency re-scan (catches new deps from arch review)
    dep_rescan [
        shape=parallelogram,
        label="npm audit / pip-audit\n(re-scan after arch changes)"
    ]

    // Gate 2b: SAST -- Two-layer static analysis
    sast_layer1 [
        shape=parallelogram,
        label="semgrep --config=auto $workspace\n(deterministic, <60s)"
    ]
    sast_layer1_check [shape=diamond, label="SAST\nFindings?"]

    sast_layer2 [
        shape=box,
        prompt="You are the Sentinel AI security agent.\n\nSAST Layer 1 (semgrep) produced these findings:\n$sast_findings\n\nPerform deeper analysis:\n1. Data flow tracing -- can the finding actually be reached?\n2. Business logic analysis -- is the pattern dangerous in this context?\n3. Adversarial verification -- construct a plausible attack path or downgrade\n4. Contextual reasoning -- is this a false positive from framework patterns?\n\nFor each finding, output: confirmed | downgraded | false_positive\nWith evidence and reasoning."
    ]
    sast_verdict [shape=diamond, label="Confirmed\nFindings?"]
    sast_blocked [shape=house, label="BLOCK\nCritical SAST\n-> Security Triage"]

    // Gate 2c: SBOM generation
    sbom_generate [
        shape=parallelogram,
        label="syft $workspace -o spdx-json\n(Software Bill of Materials)"
    ]

    gate2_pass [shape=Msquare, label="Gate 2 PASS\n-> TDD Pipeline"]

    // =============================================
    // GATE 3 -- Pre-Container Start
    // =============================================

    gate3_start [shape=Mdiamond, label="Container Built\n(image ready)"]

    // Gate 3a: Network isolation validation
    netiso_scan [
        shape=box,
        prompt="Validate network isolation and egress policy for the container:\n$container_config\n\nCheck:\n- Egress rules: only allowed destinations (package registries, API endpoints)\n- No unrestricted outbound internet access\n- DNS filtering configured\n- Inter-container network segmentation\n- Volume mount restrictions (no host filesystem leaks)\n\nOutput: PASS (policy compliant) | WARN (minor gaps) | BLOCK (unrestricted egress)"
    ]

    // Gate 3b: Container image vulnerability scan (trivy)
    image_scan [
        shape=parallelogram,
        label="trivy image $image_name\n--severity CRITICAL,HIGH"
    ]
    image_verdict [shape=diamond, label="Image\nCVEs?"]
    image_blocked [shape=house, label="BLOCK\nCritical Image CVEs\n-> Security Triage"]

    gate3_pass [shape=Msquare, label="Gate 3 PASS\n-> Container Start"]

    // =============================================
    // GATE 4 -- Pre-PR (incremental scan on diff)
    // =============================================

    gate4_start [shape=Mdiamond, label="Code Complete\n(tests pass, review done)"]

    secret_scan_incremental [
        shape=parallelogram,
        label="gitleaks detect --source $workspace\n--log-opts HEAD~1..HEAD"
    ]
    gate4_verdict [shape=diamond, label="New Secrets\nin Diff?"]
    gate4_blocked [shape=house, label="BLOCK\nSecrets in PR\n-> Security Triage"]

    gate4_pass [shape=Msquare, label="Gate 4 PASS\n-> Gate 5"]

    // =============================================
    // GATE 5 -- AI Security Review of Diff
    // =============================================

    gate5_start [shape=Mdiamond, label="Gate 4 Passed\n(no secrets in diff)"]

    security_review [
        shape=box,
        prompt="You are the Sentinel security reviewer.\n\nReview the PR diff with full context:\n- Story/issue context: $story_context\n- Architecture guidance: $engineering_brief\n- SAST Layer 1 results: $sast_report\n\nCheck the diff for:\n- Input validation at system boundaries\n- Output encoding (HTML, SQL, shell)\n- Authentication/Authorization consistency\n- Error handling (no sensitive info leaks in errors)\n- Cryptography (no MD5, no ECB, no hardcoded IVs)\n- New dependency additions\n- SSRF / Path traversal vulnerabilities\n- Hardcoded credentials\n\nAdversarial verification: findings without a plausible attack path are downgraded.\n\nOutput verdict:\n- CRITICAL: PR not created, issue flagged, Dark Forge attempts fix\n- HIGH: PR created with security-review-required label, human must acknowledge\n- CLEAN: PR created normally, findings (if any) in description"
    ]
    gate5_verdict [shape=diamond, label="Security\nReview?"]
    gate5_critical [shape=house, label="CRITICAL\nPR Blocked\n-> Dark Forge Fix"]
    gate5_high [shape=Msquare, label="HIGH\nPR + security-review-required\nlabel (human must acknowledge)"]
    gate5_clean [shape=Msquare, label="CLEAN\n-> PR Created"]

    // =============================================
    // FLOW
    // =============================================

    // Gate 1: Post-clone
    gate1_start -> secret_scan_full -> secret_classify -> secret_verdict
    secret_verdict -> dep_scan [label="CLEAN / INFO"]
    secret_verdict -> secret_blocked [label="CRITICAL"]
    dep_scan -> dep_classify -> dep_verdict
    dep_verdict -> gate1_pass [label="CLEAN"]
    dep_verdict -> dep_blocked [label="CRITICAL CVE"]

    // Gate 2: Post-architecture
    gate2_start -> dep_rescan -> sast_layer1 -> sast_layer1_check
    sast_layer1_check -> sast_layer2 [label="findings exist"]
    sast_layer1_check -> sbom_generate [label="clean"]
    sast_layer2 -> sast_verdict
    sast_verdict -> sbom_generate [label="all downgraded\nor false positive"]
    sast_verdict -> sast_blocked [label="confirmed CRITICAL"]
    sbom_generate -> gate2_pass

    // Gate 3: Pre-container
    gate3_start -> netiso_scan -> image_scan -> image_verdict
    image_verdict -> gate3_pass [label="CLEAN"]
    image_verdict -> image_blocked [label="CRITICAL CVE"]

    // Gate 4: Pre-PR (incremental)
    gate4_start -> secret_scan_incremental -> gate4_verdict
    gate4_verdict -> gate4_pass [label="CLEAN"]
    gate4_verdict -> gate4_blocked [label="SECRETS FOUND"]

    // Gate 5: AI security review
    gate5_start -> security_review -> gate5_verdict
    gate5_verdict -> gate5_clean [label="CLEAN / MEDIUM / LOW"]
    gate5_verdict -> gate5_high [label="HIGH"]
    gate5_verdict -> gate5_critical [label="CRITICAL"]
}
