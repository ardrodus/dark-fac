// Sentinel: Security Scan Pipeline
//
// ARCHITECTURE: This DOT file IS the security implementation.
// Sentinel is a first-class pillar of Dark Factory, invoked the same way
// as Dark Forge and Crucible: engine.run_pipeline("sentinel", context).
// ALL scan logic lives HERE — not in Python.
//
// Sentinel is the bio-recon soldier at the factory gates.  New code comes
// in, Sentinel checks your ID and takes a DNA sample to make sure you
// won't contaminate the factory.  One job: detect malicious or dangerous
// code.
//
// Scan pass:
//   1. Secret scan — leaked credentials, API keys, tokens
//   2. Dependency audit — known-compromised packages
//   3. SAST — injection vulnerabilities, backdoors, dangerous patterns
//   4. Classify and verdict
//
// Verdict: CLEAN | CONTAMINATED
//
// Entry point: engine.run_pipeline("sentinel", {workspace_root: ...})
// Follows: invoke → gather deps → execute (same as all pillars)

digraph sentinel {
    graph [
        goal="Scan incoming code for secrets, vulnerable dependencies, and dangerous patterns"
    ]

    // --- Entry ---
    start [shape=Mdiamond, label="Code Received\n(workspace ready)"]

    // --- Secret Scan ---
    secret_scan [
        shape=parallelogram,
        label="Secret Scan\n(gitleaks + trufflehog)",
        prompt="cd $workspace && mkdir -p .dark-factory/sentinel && (gitleaks detect --source . --report-format json --report-path .dark-factory/sentinel/secrets.json 2>&1 || true) && (trufflehog filesystem . --json > .dark-factory/sentinel/trufflehog.json 2>&1 || true)",
        timeout="5m"
    ]

    // --- Dependency Audit ---
    dep_audit [
        shape=parallelogram,
        label="Dependency Audit\n(auto-detected package manager)",
        prompt="cd $workspace && mkdir -p .dark-factory/sentinel && ([ -f requirements.txt ] && pip-audit -f json > .dark-factory/sentinel/dep-audit.json 2>&1 || [ -f package-lock.json ] && npm audit --json > .dark-factory/sentinel/dep-audit.json 2>&1 || [ -f Cargo.toml ] && cargo audit --json > .dark-factory/sentinel/dep-audit.json 2>&1 || echo '{\"info\": \"no supported package manager detected\"}' > .dark-factory/sentinel/dep-audit.json)",
        timeout="5m"
    ]

    // --- SAST (Static Analysis) ---
    sast_scan [
        shape=parallelogram,
        label="SAST Scan\n(semgrep)",
        prompt="cd $workspace && mkdir -p .dark-factory/sentinel && semgrep --config=auto . --json > .dark-factory/sentinel/sast.json 2>&1",
        timeout="10m"
    ]

    // --- Classify Results ---
    classify [
        shape=box,
        label="Classify Findings",
        prompt="You are Sentinel, Dark Factory's security scanner.\n\nWorkspace: $workspace\n\nRead all scan results:\n- Secrets: $workspace/.dark-factory/sentinel/secrets.json and trufflehog.json\n- Dependencies: $workspace/.dark-factory/sentinel/dep-audit.json\n- SAST: $workspace/.dark-factory/sentinel/sast.json\n\nFor each finding, classify:\n- CRITICAL: Active credentials, known-exploited CVEs (CVSS >= 9), confirmed injection/RCE\n- WARNING: Low-confidence patterns, high-but-unexploited CVEs, test/example secrets\n- INFO: False positives, framework patterns, test fixtures\n\nA finding is CRITICAL only if it has a plausible attack path.\nTest secrets (.env.example, fixtures, mock data) are INFO, not CRITICAL.\n\nWrite classification to: $workspace/.dark-factory/sentinel/classification.json\n\nOutput the single word: CLEAN (zero critical findings) or CONTAMINATED (any critical finding)"
    ]

    // --- Verdict ---
    verdict [shape=diamond, label="Verdict?"]
    clean [shape=Msquare, label="CLEAN\nCode is safe"]
    contaminated [shape=Msquare, label="CONTAMINATED\nCritical findings detected"]

    // --- Flow ---
    start -> secret_scan -> dep_audit -> sast_scan -> classify -> verdict
    verdict -> clean [label="CLEAN"]
    verdict -> contaminated [label="CONTAMINATED"]
}
